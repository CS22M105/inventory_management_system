# Environment template for local development and production secret stores.
# Copy to .env only for local development. Never commit real .env files.
# In production, set these values in the hosting platform's secret/environment
# configuration UI instead of storing them in git.

# Required in production.
APP_ENV=development
SECRET_KEY=replace-with-generated-secret-key

# DATABASE_URL is used by BOTH the Flask app and the Alembic migrations
# (migrations/env.py reads it from the environment). Keep the connection URL
# here / in the platform secret store only; never hardcode it in alembic.ini.
DATABASE_URL=postgresql://localhost/inventory_management_system

# Public URL used in invite/reset emails and QR links.
APP_BASE_URL=http://127.0.0.1:5001

# Optional per-customer QR/barcode prefix.
BARCODE_PREFIX=KATZ-NURS

# Account/session tunables.
SESSION_IDLE_MINUTES=30
SUDO_MODE_MAX_AGE=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

# Rate-limit tunables.
# For production with multiple workers/hosts, use a shared store such as Redis
# instead of memory://.
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_LOGIN=10 per minute
RATELIMIT_PASSWORD=5 per minute
RATELIMIT_STOCK=60 per minute

# Transaction history pagination.
TRANSACTIONS_PAGE_SIZE=50

# Error monitoring. Leave SENTRY_DSN blank for local development.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Gunicorn runtime tunables.
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_ACCESSLOG=-
GUNICORN_ERRORLOG=-
GUNICORN_LOGLEVEL=info

# TLS/proxy deployment settings.
# Keep these enabled in production when the app is behind a TLS-terminating
# platform/reverse proxy that sends X-Forwarded-* headers.
PROXY_FIX_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false

# Real invite/reset emails are sent only when SMTP is configured.
# Leave EMAIL_PROVIDER blank during local development to print/show invite links.
EMAIL_PROVIDER=
EMAIL_FROM=inventory@example.edu
SMTP_HOST=smtp.example.edu
SMTP_PORT=587
SMTP_USERNAME=inventory@example.edu
SMTP_PASSWORD=replace-with-email-password-or-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
